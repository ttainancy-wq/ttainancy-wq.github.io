  "sentencePatterns": [
    {
      "id": "bb-see",
      "pattern": "I see a {color} {animal}.",
      "slots": ["color", "animal"],
      "replacements": {
        "color": ["brown", "red", "yellow", "green"],
        "animal": ["bear", "bird", "duck", "frog"]
      },
      "questionForms": ["Do you see a {color} {animal}?", "What can you see?", "What color is the {animal}?"],
      "answerForms": ["Yes, I do.", "I see a {color} {animal}.", "It is {color}."],
      "levels": ["I see a {animal}.", "I see a {color} {animal}.", "I see two {color} {animal}s.", "I can see a {color} {animal} near the tree."],
      "examples": ["I see a brown bear.", "I see a red bird."]
    },
    {
      "id": "bb-place",
      "pattern": "The {animal} is beside the {place}.",
      "slots": ["animal", "place"],
      "replacements": {
        "animal": ["duck", "frog", "bear", "bird"],
        "place": ["pond", "tree"]
      },
      "questionForms": ["Where is the {animal}?"],
      "answerForms": ["The {animal} is beside the {place}."],
      "levels": ["The {animal} is here.", "The {animal} is beside the {place}.", "Two {animal}s are beside the {place}."],
      "examples": ["The duck is beside the pond."]
    },
    {
      "id": "bb-can",
      "pattern": "The {animal} can {action}.",
      "slots": ["animal", "action"],
      "replacements": {
        "animal": ["frog", "duck", "bird", "bear"],
        "action": ["jump", "swim", "fly", "walk"]
