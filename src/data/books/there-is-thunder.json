  "sentencePatterns": [
    {
      "id": "tt-there",
      "pattern": "There is {weather} {position}.",
      "slots": ["weather", "position"],
      "replacements": {
        "weather": ["thunder", "lightning", "rain", "a dark cloud"],
        "position": ["far away", "over the forest", "in the sky"]
      },
      "questionForms": ["What is there {position}?", "Is there {weather}?"],
      "answerForms": ["There is {weather}.", "Yes, there is."],
      "levels": ["There is {weather}.", "There is {weather} {position}.", "There is loud {weather} {position}."],
      "examples": ["There is thunder far away."]
    },
    {
      "id": "tt-action",
      "pattern": "{weather} {action} in the {place}.",
      "slots": ["weather", "action", "place"],
      "replacements": {
        "weather": ["Lightning", "Rain", "A dark cloud"],
        "action": ["flashes", "falls", "moves"],
        "place": ["sky", "forest", "garden"]
      },
      "questionForms": ["What {action} in the {place}?", "Where does {weather} {action}?"],
      "answerForms": ["{weather} {action} in the {place}."],
      "levels": ["{weather} {action}.", "Bright {weather} {action} in the {place}."],
      "examples": ["Lightning flashes in the sky."]
    },
    {
      "id": "tt-safe",
      "pattern": "The {person} is safe {position}.",
      "slots": ["person", "position"],
      "replacements": {
        "person": ["child", "cat", "family", "dog"],
        "position": ["inside", "in the house"]
      },
      "questionForms": ["Where is the {person}?", "Is the {person} safe?"],
      "answerForms": ["The {person} is safe {position}.", "Yes, the {person} is safe."],
      "levels": ["The {person} is safe.", "The {person} is safe {position}.", "The little {person} is safe {position} during the storm."],
      "examples": ["The cat is safe inside."]
    }
  ],
